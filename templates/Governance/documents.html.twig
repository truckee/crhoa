                    <table class="table">
                        <thead>
                            <tr>
                                <th>Document</th>
                                <th>Description</th>
                            </tr>
                        </thead>
                        <tr>
                            <td><a href="{{ asset('pdfs/documents/CRHOA_CCRS.pdf') }}" target="_blank">CC&amp;R</a></td>
